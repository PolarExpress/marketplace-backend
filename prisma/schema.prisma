datasource db {
    provider = "mongodb"
    url = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "debian-openssl-1.1.x", "darwin-arm64"]
}

enum AddonCategory {
    VISUALISATION
    MACHINE_LEARNING
    DATA_SOURCE
}

model User {
    id                  String @id @default(cuid()) @map("_id") @db.ObjectId
    name                String
    email               String @unique()
    author              Author?
    installedAddonID    String[] @db.ObjectId
    installedAddons     Addon[] @relation(fields: [installedAddonID], references: [id])
}

model Author{
    id                  String @id @default(cuid()) @map("_id") @db.ObjectId
    userID              String @unique @db.ObjectId
    user                User @relation(fields:[userID], references: [id])
    createdAddons       Addon[]
}

model Addon {
    id String @id @default(cuid()) @map("_id") @db.ObjectId
    name                String
    summary             String
    icon                String
    category            AddonCategory
    installedByID       String[] @db.ObjectId
    installedBy         User[] @relation(fields: [installedByID], references: [id])
    authorId            String @db.ObjectId
    author              Author @relation(fields: [authorId], references: [id])
}